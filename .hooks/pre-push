#!/bin/bash

set -e

ROOT_DIR=$(git rev-parse --show-toplevel)
cd "$ROOT_DIR"

CORE_DIR="$ROOT_DIR/core"
PRIMARY_PROJECT_DIR="$CORE_DIR"
SECONDARY_PROJECT_DIR="$CORE_DIR/python-venv2"
declare -a SECONDARY_SCOPE_PATHS=()
# shellcheck disable=SC2034
declare -a EMPTY_PATHS=()

isort_args=(--check-only --diff)
black_args=(--check --diff)
fixing=false
fix_primary=false
fix_secondary=false
should_run_primary=true
should_run_secondary=true
if [ "${#SECONDARY_SCOPE_PATHS[@]}" -eq 0 ]; then
    should_run_secondary=false
fi

print_usage() {
    cat <<'EOF'
Usage: .hooks/pre-push [options]

Options:
  --fix                   Run formatters (isort/black) for both environments and skip other checks.
  --fix-primary           Same as --fix but limited to the primary environment.
  --fix-secondary         Same as --fix but limited to the secondary environment.
  -h, --help              Show this help message.
EOF
}

require_command() {
    local cmd="$1"
    local message="$2"
    if ! command -v "$cmd" >/dev/null 2>&1; then
        echo "${message}" >&2
        exit 1
    fi
}

check_required_tools() {
    require_command uv "uv is not installed. Aborting. Please install it and try again."
    require_command poetry "poetry is not installed. Aborting. Please install it and try again."
    require_command shellcheck "shellcheck is not installed. Aborting. Please install it and try again."
    require_command parallel "parallel is not installed. Aborting. Please install it and try again."
    require_command python3 "python3 is not installed. Aborting. Please install it and try again."
}

run_nginx_validation() {
    local nginxVersion=1.22.1
    docker run --rm -v "$CORE_DIR/tools/nginx/:/nginx/:ro" nginx:"$nginxVersion" nginx -c /nginx/nginx.conf -t
}

bootstrap_runtime_dependencies() {
    echo "installing mavlink-server"
    "$CORE_DIR/tools/mavlink_server/bootstrap.sh"
    echo "installing ardupilot_tools"
    NOSUDO=1 "$CORE_DIR/tools/ardupilot_tools/bootstrap.sh"
    "$CORE_DIR/tools/ardupilot_tools/setup-python-libs.sh"
}

setup_python_environment() {
    local env_label="$1"
    local project_dir="$2"
    echo "Setting up ${env_label} environment"
    uv sync --all-groups --project "$project_dir"
    # shellcheck disable=SC1091
    source "$project_dir/.venv/bin/activate"
    export VIRTUAL_ENV="$project_dir/.venv"
    export PATH="$VIRTUAL_ENV/bin:$PATH"
}

load_secondary_scope_paths() {
    if [ -n "${BLUEOS_SECONDARY_SCOPE:-}" ]; then
        read -r -a SECONDARY_SCOPE_PATHS <<<"${BLUEOS_SECONDARY_SCOPE}"
        return
    fi

    local pyproject="$SECONDARY_PROJECT_DIR/pyproject.toml"
    if [ ! -f "$pyproject" ]; then
        SECONDARY_SCOPE_PATHS=()
        return
    fi

    mapfile -t SECONDARY_SCOPE_PATHS < <(
        CORE_DIR="$CORE_DIR" PYPROJECT_PATH="$pyproject" python3 <<'PY'
import os
import pathlib
import sys

try:
    import tomllib  # type: ignore[attr-defined]
except ModuleNotFoundError:
    try:
        import tomli as tomllib  # type: ignore[assignment]
    except ModuleNotFoundError:
        tomllib = None

core_dir = pathlib.Path(os.environ["CORE_DIR"]).resolve()
pyproject_path = pathlib.Path(os.environ["PYPROJECT_PATH"]).resolve()

if tomllib is None:
    sys.exit(0)

try:
    doc = tomllib.loads(pyproject_path.read_text())
except Exception:
    sys.exit(0)

members = (
    doc.get("tool", {})
    .get("uv", {})
    .get("workspace", {})
    .get("members", [])
)

for member in members:
    candidate = (pyproject_path.parent / member).resolve()
    try:
        rel = candidate.relative_to(core_dir)
    except ValueError:
        continue
    rel_posix = rel.as_posix()
    if rel_posix.startswith("services/"):
        print(rel_posix)
PY
    )
}

load_secondary_scope_paths
if [ "${#SECONDARY_SCOPE_PATHS[@]}" -eq 0 ]; then
    should_run_secondary=false
fi

path_matches_any() {
    local file="$1"
    shift || true
    local scope_path
    for scope_path in "$@"; do
        [[ -z "$scope_path" ]] && continue
        if [[ "$file" == "$scope_path" ]] || [[ "$file" == "$scope_path/"* ]]; then
            return 0
        fi
    done
    return 1
}

collect_python_files() {
    local scope="$1"
    local -a all_python_files=()
    mapfile -t all_python_files < <(git -C "$CORE_DIR" ls-files '*.py')

    local -a filtered=()
    local file
    for file in "${all_python_files[@]}"; do
        [[ -z "$file" ]] && continue
        if path_matches_any "$file" "${SECONDARY_SCOPE_PATHS[@]}"; then
            if [ "$scope" = "secondary" ]; then
                filtered+=("$file")
            fi
        else
            if [ "$scope" = "primary" ]; then
                filtered+=("$file")
            fi
        fi
    done

    printf '%s\n' "${filtered[@]}"
}

collect_mypy_targets() {
    local scope="$1"
    local -a all_projects=()
    mapfile -t all_projects < <(git -C "$CORE_DIR" ls-files '*/pyproject.toml')

    local -a filtered=()
    local project
    for project in "${all_projects[@]}"; do
        [[ -z "$project" ]] && continue
        case "$project" in
            libs/*|services/*)
                ;;
            *)
                continue
                ;;
        esac

        if path_matches_any "$project" "${SECONDARY_SCOPE_PATHS[@]}"; then
            if [ "$scope" = "secondary" ]; then
                filtered+=("$(dirname "$project")")
            fi
        else
            if [ "$scope" = "primary" ]; then
                filtered+=("$(dirname "$project")")
            fi
        fi
    done

    printf '%s\n' "${filtered[@]}"
}

run_python_checks() {
    local env_label="$1"
    local scope="$2"
    local pytest_ignores_ref="$3"
    local pytest_targets_ref="$4"
    local -n pytest_ignores="$pytest_ignores_ref"
    local -n pytest_targets="$pytest_targets_ref"

    echo "Running Python tooling for ${env_label}"

    local python_files=()
    mapfile -t python_files < <(collect_python_files "$scope")

    if [ "${#python_files[@]}" -eq 0 ]; then
        echo "No Python files found for ${env_label}, skipping."
        return
    fi

    pushd "$CORE_DIR" >/dev/null

    echo "Running isort (${env_label}).."
    isort "${isort_args[@]}" "${python_files[@]}"

    echo "Running black (${env_label}).."
    black "${black_args[@]}" "${python_files[@]}"

    if [ "$fixing" = true ]; then
        popd >/dev/null
        return
    fi

    echo "Running ruff (${env_label}).."
    ruff "${python_files[@]}"

    echo "Running pylint (${env_label}).."
    pylint "${python_files[@]}"

    local mypy_targets=()
    mapfile -t mypy_targets < <(collect_mypy_targets "$scope")
    if [ "${#mypy_targets[@]}" -gt 0 ]; then
        echo "Running mypy (${env_label}).."
        printf '%s\n' "${mypy_targets[@]}" | parallel mypy --config-file "$CORE_DIR/pyproject.toml" {} --cache-dir {}/__mypycache__
    fi

    echo "Running pytest (${env_label}).."
    local pytest_args=(-n 10 --durations=0 --cov="$ROOT_DIR" --cov-report html)
    local ignore_path
    for ignore_path in "${pytest_ignores[@]}"; do
        [[ -z "$ignore_path" ]] && continue
        pytest_args+=(--ignore "$ignore_path")
    done
    if [ "${#pytest_targets[@]}" -gt 0 ]; then
        pytest_args+=("${pytest_targets[@]}")
    fi
    pytest "${pytest_args[@]}"

    popd >/dev/null
}

run_environment_phase() {
    local env_label="$1"
    local project_dir="$2"
    local scope="$3"
    local pytest_ignores_ref="$4"
    local pytest_targets_ref="$5"
    local run_bootstrap="${6:-false}"

    (
        setup_python_environment "$env_label" "$project_dir"
        if [ "$run_bootstrap" = true ]; then
            bootstrap_runtime_dependencies
        fi
        run_python_checks "$env_label" "$scope" "$pytest_ignores_ref" "$pytest_targets_ref"
    )
}

for arg in "$@"; do
    case $arg in
        --fix)
            isort_args=()
            black_args=()
            fixing=true
            fix_primary=true
            fix_secondary=true
            ;;
        --fix-primary)
            isort_args=()
            black_args=()
            fixing=true
            fix_primary=true
            ;;
        --fix-secondary)
            isort_args=()
            black_args=()
            fixing=true
            fix_secondary=true
            ;;
        -h|--help)
            print_usage
            exit 0
            ;;
        *)
            echo "Unknown argument: $arg"
            print_usage
            exit 1
            ;;
    esac
done

if [ "$fixing" = true ]; then
    should_run_primary=$fix_primary
    should_run_secondary=$fix_secondary
    if [ "$should_run_primary" = false ] && [ "$should_run_secondary" = false ]; then
        should_run_primary=true
        should_run_secondary=true
    fi
    echo "Fix mode enabled. Running isort/black only in the selected environments."
fi

check_required_tools
run_nginx_validation

echo "Running pre push hook!"
tag_name=$(git tag --points-at=HEAD | head -n 1)

if [ -n "$tag_name" ]; then
    echo "Current reference has the following tag: ${tag_name}"
    if dialog --defaultno --yesno "Are you pushing a tag ?" 20 60; then
        echo "Checking tag name.."
        if ! echo "$tag_name" | grep -Po "^\d+\.\d+\.\d+(\-[A-z]+\.\d+)?$|^\d+\.\d+\.\d+$" >/dev/null; then
            echo "Invalid tag name!"
            exit 1
        fi
        echo "Tag name is valid, congratulations for the new release!"
    fi
fi

echo "Running shellcheck..."
#SC2005: Allow us to break line while running command
#SC2015: Allow us to use short circuit
#SC2046: Allow word splitting
#SC2048: Allow word splitting
#SC2086: Allow word splitting
git ls-files '*.sh' | xargs -L 1 shellcheck --exclude=SC2005,SC2015,SC2046,SC2048,SC2086

if [ "$should_run_primary" = true ]; then
    run_environment_phase "primary" "$PRIMARY_PROJECT_DIR" "primary" SECONDARY_SCOPE_PATHS EMPTY_PATHS true
fi
if [ "$should_run_secondary" = true ]; then
    if [ "${#SECONDARY_SCOPE_PATHS[@]}" -eq 0 ]; then
        echo "No services assigned to the secondary environment; skipping secondary run."
    else
        run_environment_phase "secondary" "$SECONDARY_PROJECT_DIR" "secondary" EMPTY_PATHS SECONDARY_SCOPE_PATHS
    fi
fi

exit 0
